{
  "name": "service-notification",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node24 --clean --dts",
    "dev": "tsx watch src/index.ts",
    "start": "node --no-warnings=ExperimentalWarning dist/index.js",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.38.4",
    "node-cron": "^4.2.1",
    "pino": "^10.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.13"
  }
}
